{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/requirement.schema.json",
  "title": "HR Compliance Requirement",
  "type": "object",
  "required": [
    "requirement_id",
    "source_type",
    "source_title",
    "source_document_id",
    "jurisdiction",
    "topic",
    "requirement_text",
    "normalized_obligation",
    "risk_level",
    "owner_function",
    "confidence",
    "status"
  ],
  "properties": {
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-(LAW|POL)-\\d{5}$"
    },
    "source_type": {
      "type": "string",
      "enum": ["external_law", "internal_policy", "sop", "guideline", "contractual"]
    },
    "source_title": {
      "type": "string",
      "minLength": 1
    },
    "source_document_id": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 2
    },
    "article_ref": {
      "type": "string"
    },
    "clause_ref": {
      "type": "string"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "requirement_text": {
      "type": "string",
      "minLength": 10
    },
    "normalized_obligation": {
      "type": "string",
      "minLength": 10
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "trigger_event": {
      "type": "string"
    },
    "deadline_rule": {
      "type": "string"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "penalty_or_impact": {
      "type": "string"
    },
    "owner_function": {
      "type": "string",
      "minLength": 1
    },
    "review_cycle": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "needs_review"]
    }
  },
  "additionalProperties": false
}
