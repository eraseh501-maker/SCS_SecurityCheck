{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/control_point.schema.json",
  "title": "HR Compliance Control Point",
  "type": "object",
  "required": [
    "control_id",
    "control_name",
    "control_type",
    "automation_level",
    "objective",
    "frequency",
    "process_area",
    "owner_role",
    "rule_logic",
    "evidence_artifacts",
    "linked_requirements",
    "status"
  ],
  "properties": {
    "control_id": {
      "type": "string",
      "pattern": "^CTRL-[A-Z]{3,6}-\\d{5}$"
    },
    "control_name": {
      "type": "string",
      "minLength": 5
    },
    "control_type": {
      "type": "string",
      "enum": ["preventive", "detective", "compensating"]
    },
    "automation_level": {
      "type": "string",
      "enum": ["manual", "semi_automated", "automated"]
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "frequency": {
      "type": "string",
      "enum": ["real_time", "daily", "weekly", "monthly", "quarterly", "semiannual", "annual", "per_payroll_cycle", "event_driven"]
    },
    "process_area": {
      "type": "string",
      "minLength": 1
    },
    "owner_role": {
      "type": "string",
      "minLength": 1
    },
    "input_data": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "rule_logic": {
      "type": "string",
      "minLength": 10
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean"]
      },
      "default": {}
    },
    "exceptions_handling": {
      "type": "string"
    },
    "evidence_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "linked_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^REQ-(LAW|POL)-\\d{5}$"
      }
    },
    "residual_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "test_procedure": {
      "type": "string"
    },
    "kri": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "active", "needs_review", "retired"]
    }
  },
  "additionalProperties": false
}
